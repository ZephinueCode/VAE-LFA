{
  "dataset": {
    "path": "data/train_dataset",
    "image_size": 768
  },
  "sampling": {
    "pairs": [
      {
        "source_round": 3,
        "target_round": 2,
        "probability": 0.10
      },
      {
        "source_round": 2,
        "target_round": 1,
        "probability": 0.25
      },
      {
        "source_round": 1,
        "target_round": 0,
        "probability": 0.35
      },
      {
        "source_round": 2,
        "target_round": 0,
        "probability": 0.20
      },
      {
        "source_round": 3,
        "target_round": 0,
        "probability": 0.10
      }
    ]
  },
  "adapter": {
    "hidden_multiplier": 4,
    "num_blocks": 4,
    "dropout": 0.0
  },
  "loss": {
    "type": "latent",
    "lpips_net": "alex"
  },
  "train": {
    "output_dir": "models/adapter/",
    "batch_size": 4,
    "num_workers": 4,
    "num_epochs": 1,
    "steps_per_epoch": 1024,
    "learning_rate": 1e-4,
    "weight_decay": 0.0,
    "adam_beta1": 0.9,
    "adam_beta2": 0.999,
    "adam_epsilon": 1e-08,
    "warmup_steps": 100,
    "gradient_accumulation_steps": 2,
    "max_grad_norm": 1.0,
    "mixed_precision": "fp16",
    "seed": 42,
    "save_every_steps": 500,
    "log_every_steps": 10
  },
  "intervention": {
    "enabled": false,
    "strength": 0.22,
    "direction_suppress": 0.45,
    "radial_jitter": 0.05,
    "max_freq_suppress": 0.2,
    "noise_std": 0.01,
    "channel_dropout_prob": 0.01,
    "channel_shuffle_prob": 0.02,
    "preserve_mean": false,
    "preserve_std": false
  }
}
